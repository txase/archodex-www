---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

export interface Props {
  title?: string;
  prefill?: string;
  metadata?: { title: string; description: string };
}

const metadata = Astro.props.metadata || { title: 'Contact', description: 'Contact | Archodex' };

const { title, prefill } = Astro.props;
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText title={title || 'Contact'} />

  {
    Astro.slots.has('default') && (
      <WidgetWrapper>
        <slot />
      </WidgetWrapper>
    )
  }

  <ContactUs
    id="form"
    classes={{ container: 'pt-0 md:pt-0 lg:pt-0' }}
    inputs={[
      { type: 'hidden', name: 'subject', value: 'Contact Form Submission' },
      { type: 'text', name: 'name', label: 'Name' },
      { type: 'email', name: 'email', label: 'Email' },
    ]}
    textarea={{ label: 'Message', defaultValue: prefill }}
    button="Submit"
  />
</Layout>
